{
  // ── Editor — minimal, predictable ──────────────────────────────────
  "editor.fontFamily": "DejaVuSansM Nerd Font Mono, Menlo, monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.5,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.renderWhitespace": "boundary",
  "editor.cursorBlinking": "solid",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "auto",
  "editor.scrollbar.horizontal": "auto",
  "editor.bracketPairColorization.enabled": false,
  "editor.guides.bracketPairs": false,
  "editor.smoothScrolling": false,
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.suggest.preview": false,
  "editor.inlineSuggest.enabled": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.formatOnSave": false,
  "editor.linkedEditing": false,

  // ── Files ──────────────────────────────────────────────────────────
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "off",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/node_modules": true
  },

  // ── Workbench — quiet UI ───────────────────────────────────────────
  "workbench.colorTheme": "Solarized Dark",
  "workbench.iconTheme": null,
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": true,
  "workbench.tips.enabled": false,
  "workbench.welcomePage.walkthroughs.openOnInstall": false,
  "breadcrumbs.enabled": false,

  // ── Window ─────────────────────────────────────────────────────────
  "window.titleBarStyle": "native",
  "window.commandCenter": false,
  "window.menuBarVisibility": "compact",

  // ── Terminal ───────────────────────────────────────────────────────
  "terminal.integrated.fontFamily": "DejaVuSansM Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.defaultProfile.osx": "zsh",

  // ── Telemetry & noise off ──────────────────────────────────────────
  "telemetry.telemetryLevel": "off",
  "update.showReleaseNotes": false,
  "extensions.ignoreRecommendations": true,
  "git.confirmSync": false,
  "git.autofetch": false,
  "scm.diffDecorations": "gutter",

  // ── Vim extension (vscodevim) — load if installed ─────────────────
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.smartcase": true,
  "vim.leader": " ",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },

  // ── Language-specific overrides ────────────────────────────────────
  "[python]": { "editor.tabSize": 4 },
  "[go]":     { "editor.tabSize": 4, "editor.insertSpaces": false },
  "[rust]":   { "editor.tabSize": 4 },
  "[makefile]": { "editor.insertSpaces": false }
}
