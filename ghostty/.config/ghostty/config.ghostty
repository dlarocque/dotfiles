font-family = "DejaVuSansM Nerd Font Mono"
font-size = 16

# Pure black background; everything else (foreground, palette) inherits
# ghostty's defaults. Bump to #0a0a0a or #111111 if pure black feels harsh.
background = #000000
# Browse alternatives with: ghostty +list-themes
# Switch to a theme later with: theme = <name>  (will override `background`)
