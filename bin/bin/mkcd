#!/usr/bin/env bash
# mkcd DIR — mkdir DIR (with parents) then cd into it.
# Must be sourced or used as a function to actually cd in the calling shell.
# This standalone version prints the path so you can `cd "$(mkcd foo)"`.

set -euo pipefail

if [ $# -ne 1 ]; then
  echo "usage: mkcd DIR" >&2
  exit 64
fi

mkdir -p -- "$1"
cd -- "$1"
pwd
