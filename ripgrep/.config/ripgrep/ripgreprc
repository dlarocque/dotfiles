# ripgrep — sourced via RIPGREP_CONFIG_PATH (set in zshrc).
# Reference: https://github.com/BurntSushi/ripgrep/blob/master/GUIDE.md#configuration-file

--smart-case
--max-columns=150
--max-columns-preview
--hidden
--glob=!.git/*
--glob=!node_modules/*
--glob=!.venv/*
--glob=!__pycache__/*

# Default colors (override if your terminal theme prefers otherwise)
--colors=line:none
--colors=line:style:bold
--colors=path:fg:green
--colors=match:fg:black
--colors=match:bg:yellow
