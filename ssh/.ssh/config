# SSH client config — stowed to ~/.ssh/config.
# NEVER commit private keys (id_*, *.pem) or known_hosts.
# Reference: man ssh_config

# ── Defaults for every host ────────────────────────────────────────────
Host *
    # Keep idle connections alive across NAT / wifi flakiness
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Reuse connections (much faster for repeated ssh/scp/git over ssh).
    # Requires ~/.ssh/control/ to exist (bootstrap.sh creates it).
    ControlMaster auto
    ControlPath ~/.ssh/control/%r@%h:%p
    ControlPersist 10m

    # Only offer the key explicitly listed under IdentityFile (no key spam)
    IdentitiesOnly yes

    # Add keys to ssh-agent on first use.
    # UseKeychain is macOS-only and silently ignored elsewhere.
    AddKeysToAgent yes
    UseKeychain yes

# ── Example host blocks ────────────────────────────────────────────────
# Host gh
#     HostName github.com
#     User git
#     IdentityFile ~/.ssh/id_ed25519
#
# Host work-jump
#     HostName jump.example.com
#     User dlarocque
#     IdentityFile ~/.ssh/id_work
#
# Host work-internal
#     HostName 10.0.0.42
#     User dlarocque
#     ProxyJump work-jump
#     IdentityFile ~/.ssh/id_work
