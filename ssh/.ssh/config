Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ControlMaster auto
    ControlPath ~/.ssh/control/%r@%h:%p
    ControlPersist 10m
    IdentitiesOnly yes
    AddKeysToAgent yes
    UseKeychain yes

Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
